# ── Serveur ─────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=http://localhost:3333

# ── Email (SMTP) ─────────────────────────
# Exemple avec Gmail — utiliser un mot de passe d'application
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_mot_de_passe_application

# Email de réception des contacts
CONTACT_RECIPIENT=hello@nexova.agency
NEWSLETTER_RECIPIENT=newsletter@nexova.agency

# ── Sécurité ─────────────────────────────
JWT_SECRET=changer_cette_valeur_longue_et_aleatoire_en_prod
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
